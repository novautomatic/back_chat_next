# === Supabase ===
# URL del proyecto (https://xxxxx.supabase.co)
SUPABASE_URL=
# Clave anon (publica) - usada para verificar JWT de usuarios
SUPABASE_ANON_KEY=
# Clave service_role (SECRETA, solo backend) - acceso privilegiado y broadcast
SUPABASE_SERVICE_ROLE_KEY=

# === OpenAI ===
OPENAI_API_KEY=
# Modelo de chat por defecto (configurable por agente en la BD)
OPENAI_CHAT_MODEL=gpt-4o-mini
# Modelo de embeddings (1536 dims)
OPENAI_EMBED_MODEL=text-embedding-3-small

# === Servidor ===
PORT=4000
# Origenes permitidos para el dashboard (coma-separado). El widget usa CORS abierto.
DASHBOARD_ORIGINS=http://localhost:3000
